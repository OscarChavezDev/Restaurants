# ============================================================
# VARIABLES DE ENTORNO - SISTEMA DE RESTAURANTES
# Copia este archivo a .env y configura los valores
# ============================================================

# === BASE DE DATOS ===
DB_USERNAME=tingo_user
DB_PASSWORD=cambia-esta-contraseña-en-produccion

# === SPRING BOOT ===
SPRING_PROFILES_ACTIVE=dev

# === JWT ===
JWT_SECRET=cambia-este-secreto-por-uno-seguro-de-al-menos-256-bits-de-longitud-minima
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# === EMAIL (Gmail SMTP) ===
# Notificaciones de reserva (creada / confirmada / cancelada).
# Usa una "Contraseña de aplicación" de Gmail (NO tu contraseña normal):
#   https://myaccount.google.com/apppasswords  (requiere verificación en 2 pasos)
# Si se dejan vacías, la app funciona igual pero no envía correos.
MAIL_USERNAME=
MAIL_PASSWORD=

# === FRONTEND ===
NEXT_PUBLIC_API_URL=http://localhost:8080/api
